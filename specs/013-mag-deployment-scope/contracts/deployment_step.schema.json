{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deployment_step.schema.json",
  "title": "DeploymentStep",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "step_index": {
      "type": "integer",
      "minimum": 1
    },
    "micro_ag_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "step_index",
    "micro_ag_ids"
  ]
}