{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deployment_sequence.schema.json",
  "title": "DeploymentSequence",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "bypassed_edges": {
      "type": "array",
      "items": {
        "$ref": "./micro_ag_edge.schema.json"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./deployment_step.schema.json"
      }
    }
  },
  "required": [
    "bypassed_edges",
    "steps"
  ]
}