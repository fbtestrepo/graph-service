{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graph-service.local/specs/007-add-micro-affinity-endpoint/contracts/micro_affinity_group.schema.json",
  "title": "Micro Affinity Group",
  "description": "Service-level request/response contract for POST /micro-affinity-groups. Cross-collection alignment to application-architecture service nodes is enforced after schema validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "micro-ag-id",
    "parent-asset-id",
    "architecture-version",
    "environment",
    "effective-date",
    "workloads"
  ],
  "properties": {
    "micro-ag-id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "parent-asset-id": {
      "type": "string",
      "minLength": 1
    },
    "architecture-version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "effective-date": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])T([01]\\d|2[0-3]):[0-5]\\d:[0-5]\\dZ$"
    },
    "workloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/MicroAffinityGroupWorkload"
      },
      "description": "Workload IDs must be unique within a request. Architecture lookup rules are enforced outside JSON Schema."
    }
  },
  "$defs": {
    "MicroAffinityGroupWorkload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "asset-id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "asset-id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}